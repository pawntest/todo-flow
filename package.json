{
  "name": "todo-flow",
  "version": "1.0.0",
  "private": true,
  "description": "Google Todo-like application with React and Express",
  "workspaces": [
    "client",
    "server",
    "shared",
    "runner"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "start": "bash scripts/start.sh",
    "stop": "bash scripts/stop.sh",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspaces",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "db:migrate": "npm run migrate --workspace=server",
    "db:studio": "npm run studio --workspace=server",
    "db:seed": "npm run seed --workspace=server",
    "runner": "npm run start --workspace=runner",
    "runner:watch": "npm run watch --workspace=runner"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
